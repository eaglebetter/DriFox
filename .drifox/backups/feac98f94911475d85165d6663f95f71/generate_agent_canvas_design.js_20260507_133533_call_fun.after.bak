                ["参数推荐智能体", "参数已更新，置信区间[0.95, 0.98]"]
            ]),

            new Paragraph({ spacing: { before: 600 } }),
            new Paragraph({
                children: [new TextRun({ text: "— 文档结束 —", color: "999999", size: 24 })],
                alignment: AlignmentType.CENTER
            })
        ]
    }]
});

// ========== 辅助函数 ==========

function createTOCItem(text, page) {
    return new Paragraph({
        children: [
            new TextRun({ text: text, size: 24 }),
            new TextRun({ text: "  ", size: 24 }),
            new TextRun({ text: "".padEnd(Math.max(0, 40 - text.length), '．'), size: 24, color: "AAAAAA" }),
            new TextRun({ text: " " + page, size: 24 })
        ],
        spacing: { after: 100 }
    });
}

function createNormalParagraph(text) {
    return new Paragraph({
        children: [new TextRun({ text: text, size: 24 })],
        spacing: { after: 150 }
    });
}

function createBulletPoint(text) {
    return new Paragraph({
        children: [
            new TextRun({ text: "● ", size: 24, bold: true, color: "1976D2" }),
            new TextRun({ text: text, size: 24 })
        ],
        indent: { left: 360 },
        spacing: { after: 100 }
    });
}

function createFlowDiagramV2(title, bgColor) {
    const steps = "开始 → 问题描述 → 知识检索 → 多轮对话调整 → 模型入库 → 结束";
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({
                children: [
                    new TableCell({
                        children: [new Paragraph({ 
                            children: [new TextRun({ text: title, bold: true, size: 26, color: "1565C0" })],
                            alignment: AlignmentType.CENTER 
                        })],
                        shading: { fill: bgColor, type: ShadingType.CLEAR },
                        width: { size: 25, type: WidthType.PERCENTAGE }
                    }),
                    new TableCell({
                        children: [new Paragraph({ 
                            children: [new TextRun({ text: steps, size: 22 })],
                            alignment: AlignmentType.CENTER 
                        })],
                        width: { size: 75, type: WidthType.PERCENTAGE }
                    })
                ]
            })
        ]
    });
}

function createVisualLanguageTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["颜色", "含义", "对应模块"]) }),
            createDataRow(["绿色", "从零开始构建", "新建模型"]),
            createDataRow(["蓝色", "迭代和完善", "模型优化"]),
            createDataRow(["黄色", "数值微调", "参数推荐"])
        ]
    });
}

function createShapeMeaningTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["形状", "含义"]) }),
            createDataRow(["椭圆", "开始/结束节点，标志流程边界"]),
            createDataRow(["矩形框", "静态信息输入源（如知识库、描述）"]),
            createDataRow(["圆柱体", "数据库/知识检索操作"]),
            createDataRow(["圆角矩形", "处理步骤或系统输出"]),
            createDataRow(["大方框", "多轮对话调整子环境"]),
            createDataRow(["小人图标", "用户参与（人在回路）"])
        ]
    });
}

function createModuleTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["模块", "功能"]) }),
            createDataRow(["智能体管理模块", "管理和配置各类智能体"]),
            createDataRow(["工作流编排模块", "定义和执行智能体工作流"]),
            createDataRow(["知识库管理模块", "维护领域知识和模型知识"]),
            createDataRow(["画布编辑模块", "可视化编排界面"]),
            createDataRow(["模型存储模块", "存储和管理规则引擎模型"]),
            createDataRow(["对话管理模块", "处理多轮对话交互"])
        ]
    });
}

function createAgentTypeTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["智能体", "英文名", "职责"]) }),
            createDataRow(["问题分析智能体", "Problem Analysis Agent", "解析问题描述"]),
            createDataRow(["知识检索智能体", "Knowledge Retrieval Agent", "检索相关知识"]),
            createDataRow(["规则生成智能体", "Rule Generation Agent", "生成规则模型"]),
            createDataRow(["模型评价智能体", "Model Evaluation Agent", "评价和推荐"]),
            createDataRow(["对话调整智能体", "Dialog Adjustment Agent", "多轮对话调整"]),
            createDataRow(["参数推荐智能体", "Parameter Recommendation Agent", "推荐参数"])
        ]
    });
}

function createTableWithHeader(data) {
    const rows = data.map((row, index) => {
        if (index === 0) {
            return new TableRow({ children: row.map(cell => createHeaderCell(cell)) });
        }
        return new TableRow({ children: row.map(cell => createDataCell(cell)) });
    });
    return new Table({ width: { size: 100, type: WidthType.PERCENTAGE }, rows, spacing: { after: 200 } });
}

function createKnowledgeTable(data) {
    const rows = data.map((row, index) => {
        if (index === 0) {
            return new TableRow({ children: row.map(cell => createHeaderCell(cell)) });
        }
        return new TableRow({ children: row.map(cell => createDataCell(cell)) });
    });
    return new Table({ width: { size: 100, type: WidthType.PERCENTAGE }, rows, spacing: { after: 200 } });
}

function createNodeTypeTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["节点类型", "形状", "说明"]) }),
            createDataRow(["开始/结束节点", "椭圆", "流程起点/终点"]),
            createDataRow(["智能体节点", "矩形", "执行智能体任务"]),
            createDataRow(["知识库节点", "圆柱形", "表示知识库"]),
            createDataRow(["用户节点", "小人图标", "表示用户参与"]),
            createDataRow(["处理节点", "圆角矩形", "数据处理"]),
            createDataRow(["对话容器", "大方框", "多轮对话区域"])
        ]
    });
}

function createComparisonTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({ children: createHeaderCells(["维度", "新建模型", "模型优化", "参数推荐"]) }),
            createDataRow(["颜色", "绿色", "蓝色", "黄色"]),
            createDataRow(["输入复杂度", "较低", "极高", "极高"]),
            createDataRow(["检索深度", "基础规则", "模型逻辑+阈值", "模型逻辑+阈值"]),
            createDataRow(["对话输出", "规则", "评价", "参数"]),
            createDataRow(["人机交互", "调整规则结构", "问答完善", "确认数值"]),
            createDataRow(["核心目标", "从无到有", "纠偏补完", "锁定最优值"])
        ]
    });
}

function createHeaderCells(texts) {
    return texts.map(text => createHeaderCell(text));
}

function createHeaderCell(text) {
    return new TableCell({
        children: [new Paragraph({ children: [new TextRun({ text, bold: true, size: 22 })] })],
        shading: { fill: colors.header, type: ShadingType.CLEAR },
        verticalAlign: VerticalAlign.CENTER
    });
}

function createDataCell(text) {
    return new TableCell({
        children: [new Paragraph({ children: [new TextRun({ text, size: 22 })] })],
        verticalAlign: VerticalAlign.CENTER
    });
}

function createDataRow(...cells) {
    return new TableRow({ children: cells.map(cell => createDataCell(cell)) });
}

function createCodeBlock(code) {
    return new Paragraph({
        children: [new TextRun({ text: code, size: 20, font: "Consolas" })],
        shading: { fill: colors.lightGray, type: ShadingType.CLEAR },
        indent: { left: 360 },
        spacing: { after: 200 }
    });
}

function createDialogExample(dialogs) {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: dialogs.map(([speaker, text]) => 
            new TableRow({
                children: [
                    new TableCell({ 
                        children: [new Paragraph({ children: [new TextRun({ text: speaker, bold: true, size: 22, color: speaker === "用户" ? "1976D2" : "388E3C" })] })],
                        width: { size: 20, type: WidthType.PERCENTAGE },
                        shading: { fill: speaker === "用户" ? "E3F2FD" : "E8F5E9", type: ShadingType.CLEAR }
                    }),
                    new TableCell({ 
                        children: [new Paragraph({ children: [new TextRun({ text, size: 22 })] })],
                        width: { size: 80, type: WidthType.PERCENTAGE }
                    })
                ]
            })
        ),
        spacing: { after: 150 }
    });
}

