function createTOCItem(text, page) {
    return new Paragraph({
        children: [
            new TextRun({ text: text, size: 24 }),
            new TextRun({ text: " ", size: 24 }),
            new TextRun({ text: "".padEnd(50 - text.length, '.'), size: 24, color: "999999" }),
            new TextRun({ text: " " + page, size: 24 })
        ],
        spacing: { after: 60 }
    });
}

function createNormalParagraph(text) {
    return new Paragraph({
        children: [new TextRun({ text: text, size: 24 })],
        spacing: { after: 120 }
    });
}

function createBulletPoint(text) {
    return new Paragraph({
        children: [
            new TextRun({ text: "• ", size: 24, bold: true }),
            new TextRun({ text: text, size: 24 })
        ],
        indent: { left: 360 },
        spacing: { after: 80 }
    });
}

function createFlowDiagram(title, bgColor) {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({
                children: [
                    new TableCell({
                        children: [new Paragraph({ 
                            children: [new TextRun({ text: title, bold: true, size: 24 })],
                            alignment: AlignmentType.CENTER 
                        })],
                        shading: { fill: bgColor, type: ShadingType.CLEAR },
                        width: { size: 100, type: WidthType.PERCENTAGE }
                    })
                ]
            }),
            new TableRow({
                children: [
                    new TableCell({
                        children: [new Paragraph({ 
                            children: [new TextRun({ text: "开始 → 问题描述 → 知识检索 → 多轮对话调整 → 模型入库应用 → 结束", size: 22 })],
                            alignment: AlignmentType.CENTER 
                        })],
                        width: { size: 100, type: WidthType.PERCENTAGE }
                    })
                ]
            })
        ]
    });
}

function createModuleTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({
                children: [
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "模块名称", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } }),
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "功能描述", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } })
                ]
            }),
            createTableRow("智能体管理模块", "管理和配置各类智能体"),
            createTableRow("工作流编排模块", "定义和执行智能体工作流"),
            createTableRow("知识库管理模块", "维护领域知识和模型知识"),
            createTableRow("画布编辑模块", "可视化编排界面"),
            createTableRow("模型存储模块", "存储和管理规则引擎模型"),
            createTableRow("对话管理模块", "处理多轮对话交互")
        ]
    });
}

function createAgentTypeTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({
                children: [
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "智能体类型", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } }),
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "英文名称", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } }),
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "主要职责", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } })
                ]
            }),
            createTableRow("问题分析智能体", "Problem Analysis Agent", "解析问题描述"),
            createTableRow("知识检索智能体", "Knowledge Retrieval Agent", "检索相关知识"),
            createTableRow("规则生成智能体", "Rule Generation Agent", "生成规则模型"),
            createTableRow("模型评价智能体", "Model Evaluation Agent", "评价和推荐"),
            createTableRow("对话调整智能体", "Dialog Adjustment Agent", "多轮对话调整"),
            createTableRow("参数推荐智能体", "Parameter Recommendation Agent", "推荐最优参数")
        ]
    });
}

function createKnowledgeTable(title, data) {
    const rows = data.map((row, index) => {
        if (index === 0) {
            return new TableRow({
                children: row.map(cell => 
                    new TableCell({ 
                        children: [new Paragraph({ children: [new TextRun({ text: cell, bold: true })] })],
                        shading: { fill: colors.header, type: ShadingType.CLEAR }
                    })
                )
            });
        }
        return new TableRow({
            children: row.map(cell => 
                new TableCell({ 
                    children: [new Paragraph({ children: [new TextRun({ text: cell })] })]
                })
            )
        });
    });
    return new Table({ width: { size: 100, type: WidthType.PERCENTAGE }, rows });
}

function createNodeTypeTable() {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
            new TableRow({
                children: [
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "节点类型", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } }),
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "形状", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } }),
                    new TableCell({ children: [new Paragraph({ children: [new TextRun({ text: "说明", bold: true })] })], shading: { fill: colors.header, type: ShadingType.CLEAR } })
                ]
            }),
            createTableRow("开始节点", "白色椭圆", "流程起点"),
            createTableRow("结束节点", "白色椭圆", "流程终点"),
            createTableRow("智能体节点", "蓝色边框矩形", "执行智能体任务"),
            createTableRow("知识库节点", "圆柱形", "表示知识库"),
            createTableRow("用户节点", "小人图标", "表示用户参与"),
            createTableRow("处理节点", "圆角矩形", "数据处理"),
            createTableRow("条件节点", "菱形", "条件判断")
        ]
    });
}

function createTableRow(...cells) {
    return new TableRow({
        children: cells.map(cell => 
            new TableCell({ 
                children: [new Paragraph({ children: [new TextRun({ text: cell })] })],
                width: { size: 100 / cells.length, type: WidthType.PERCENTAGE }
            })
        )
    });
}

function createCodeBlock(code) {
    return new Paragraph({
        children: [new TextRun({ text: code, size: 20, font: "Consolas" })],
        shading: { fill: colors.lightGray, type: ShadingType.CLEAR },
        indent: { left: 360 },
        spacing: { after: 200 }
    });
}

function createDialogExample(dialogs) {
    return new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: dialogs.map(([speaker, text]) => 
            new TableRow({
                children: [
                    new TableCell({ 
                        children: [new Paragraph({ children: [new TextRun({ text: speaker, bold: true, color: speaker === "用户" ? "1976D2" : "388E3C" })] })],
                        width: { size: 20, type: WidthType.PERCENTAGE }
                    }),
                    new TableCell({ 
                        children: [new Paragraph({ children: [new TextRun({ text: text })] })],
                        width: { size: 80, type: WidthType.PERCENTAGE }
                    })
                ]
            })
        )
    });
}

Packer.toBuffer(doc).then(buffer => {
    fs.writeFileSync("D:/work/DriFox/docs/superpowers/specs/智能体画布系统设计方案.docx", buffer);
    console.log("文档生成成功！");
});
