# -*- coding: utf-8 -*-
"""
服务商编辑卡片 - 将弹窗改为卡片形式
"""
import requests
from PyQt5.QtCore import pyqtSignal, Qt, QThread
from PyQt5.QtGui import QIcon
from PyQt5.QtWidgets import (
    QWidget,
    QVBoxLayout,
    QHBoxLayout,
    QLabel,
    QFrame,
    QLineEdit,
    QDoubleSpinBox,
    QScrollArea,
)
from qfluentwidgets import (
    BodyLabel,
    StrongBodyLabel,
    LineEdit,
    PrimaryPushButton,
    PushButton,
    CardWidget,
    TransparentToolButton,
    FluentIcon,
)
from app.widgets.searchable_editable_combobox import SearchableEditableComboBox
from app.utils.utils import get_icon, get_font_family_css
from app.constants import (
    PROVIDER_ICONS,
    PROVIDER_MODELS,
    FREE_PROVIDERS,
)


class ProviderEditCard(QWidget):
    """服务商编辑卡片"""

    # 信号
    saved = pyqtSignal(str, dict)  # provider_name, provider_info
    closed = pyqtSignal()

    def __init__(self, provider_name: str = "", provider_info: dict = None, is_new: bool = True, parent=None):
        super().__init__(parent)
        self.provider_name = provider_name
        self.provider_info = (provider_info or {}).copy()
        self.is_new = is_new
        self._original_info = (provider_info or {}).copy()
        self._fetched_models = []
        self._init_ui()

    def _init_ui(self):
        self.setStyleSheet("""
            QWidget {
                background: transparent;
            }
            QLabel {
                color: #cccccc;
                background: transparent;
            }
            QDoubleSpinBox {
                background-color: #3d3d3d;
                color: #ffffff;
                border: 1px solid #555555;
                border-radius: 4px;
                padding: 4px 8px;
            }
            QDoubleSpinBox:hover {
                border-color: #0078d4;
            }
            QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
                background-color: #3d3d3d;
                border: none;
            }
            QFrame {
                background-color: rgba(51, 51, 51, 180);
                border-radius: 8px;
                border: none;
            }
            QLineEdit {
                background-color: #3d3d3d;
                color: #ffffff;
                border: 1px solid #555555;
                border-radius: 4px;
                padding: 6px 10px;
            }
            QLineEdit:focus {
                border-color: #0078d4;
            }
            QPushButton {
                background-color: #1a8cd4;
                color: white;
                border: none;
                border-radius: 4px;
                padding: 6px 16px;
                font-size: 12px;
            }
            QPushButton:hover {
                background-color: #0078d4;
            }
            QPushButton:disabled {
                background-color: #555555;
                color: #888888;
            }
        """)

        main_layout = QVBoxLayout(self)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        # 滚动区域
        scroll = QScrollArea(self)
        scroll.setWidgetResizable(True)
        scroll.setStyleSheet("""
            QScrollArea {
                border: none;
                background: transparent;
            }
            QScrollArea > QWidget > QWidget {
                background: transparent;
            }
            QScrollBar:vertical {
                border: none;
                background: transparent;
                width: 10px;
                margin: 4px 4px 4px 4px;
            }
            QScrollBar::handle:vertical {
                background: #555555;
                border-radius: 5px;
                min-height: 30px;
            }
            QScrollBar::handle:vertical:hover {
                background: #888888;
            }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                height: 0px;
            }
        """)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)

        content_widget = QWidget()
        content_layout = QVBoxLayout(content_widget)
        content_layout.setContentsMargins(16, 12, 16, 12)
        content_layout.setSpacing(16)

        # 标题
        header_label = StrongBodyLabel("添加服务商" if self.is_new else "编辑服务商")
        header_label.setStyleSheet("color: #ffffff; font-size: 14px; font-weight: bold;")
        content_layout.addWidget(header_label)

        # 连接配置区域
        connection_frame = QFrame()
        connection_frame.setStyleSheet("background-color: rgba(51, 51, 51, 180); border-radius: 8px;")
        connection_layout = QVBoxLayout(connection_frame)
        connection_layout.setContentsMargins(16, 12, 16, 12)
        connection_layout.setSpacing(12)

        conn_title = BodyLabel("连接配置")
        conn_title.setStyleSheet("color: #4fc3f7; font-size: 13px; font-weight: bold;")
        connection_layout.addWidget(conn_title)

        # 服务商名称
        if self.is_new:
            name_row = QHBoxLayout()
            name_row.addWidget(BodyLabel("服务商:"))

            self.nameCombo = SearchableEditableComboBox()
            for provider_name in FREE_PROVIDERS.keys():
                icon_name = PROVIDER_ICONS.get(provider_name, "大模型")
                icon = get_icon(icon_name)
                self.nameCombo.addItem(provider_name, icon=icon)
            self.nameCombo.setDisabled(False)
            self.nameCombo.setCurrentIndex(0)
            self.nameCombo.currentTextChanged.connect(self._on_provider_changed)
            name_row.addWidget(self.nameCombo, 1)

            self.getKeyBtn = PrimaryPushButton("获取API Key")
            self.getKeyBtn.setFixedSize(90, 28)
            self.getKeyBtn.clicked.connect(lambda: self._open_help_url(self.nameCombo.currentText()))
            name_row.addWidget(self.getKeyBtn)

            connection_layout.addLayout(name_row)
            first_provider = self.nameCombo.currentText()
            template = FREE_PROVIDERS.get(first_provider, {})
        elif self.provider_name in FREE_PROVIDERS:
            template = FREE_PROVIDERS[self.provider_name]
            name_row = QHBoxLayout()
            name_row.addWidget(BodyLabel("服务商:"))
            name_row.addWidget(BodyLabel(self.provider_name))
            name_row.addStretch()
            connection_layout.addLayout(name_row)
        else:
            template = self.provider_info
            name_row = QHBoxLayout()
            name_row.addWidget(BodyLabel("服务商:"))
            name_row.addWidget(BodyLabel(self.provider_name))
            name_row.addStretch()
            connection_layout.addLayout(name_row)

        # API URL
        url_row = QHBoxLayout()
        url_row.addWidget(BodyLabel("API URL:"))
        self.apiUrlCombo = SearchableEditableComboBox()
        self._load_preset_urls()
        current_url = self.provider_info.get("API_URL", template.get("API_URL", ""))
        if current_url:
            existing_items = [self.apiUrlCombo.itemText(i) for i in range(self.apiUrlCombo.count())]
            if current_url not in existing_items:
                self.apiUrlCombo.addItem(current_url)
            idx = self.apiUrlCombo.findText(current_url)
            if idx >= 0:
                self.apiUrlCombo.setCurrentIndex(idx)
            else:
                self.apiUrlCombo.setCurrentText(current_url)
        url_row.addWidget(self.apiUrlCombo, 1)
        connection_layout.addLayout(url_row)

        # API Key
        key_row = QHBoxLayout()
        key_row.addWidget(BodyLabel("API Key:"))
        self.apiKeyEdit = LineEdit()
        self.apiKeyEdit.setEchoMode(QLineEdit.Password)
        current_key = self.provider_info.get("API_KEY", template.get("API_KEY", ""))
        if current_key:
            self.apiKeyEdit.setText(current_key)
        key_row.addWidget(self.apiKeyEdit, 1)
        connection_layout.addLayout(key_row)

        content_layout.addWidget(connection_frame)

        # 模型配置区域
        model_frame = QFrame()
        model_frame.setStyleSheet("background-color: rgba(51, 51, 51, 180); border-radius: 8px;")
        model_layout = QVBoxLayout(model_frame)
        model_layout.setContentsMargins(16, 12, 16, 12)
        model_layout.setSpacing(12)

        model_title = BodyLabel("模型配置")
        model_title.setStyleSheet("color: #4fc3f7; font-size: 13px; font-weight: bold;")
        model_layout.addWidget(model_title)

        model_row = QHBoxLayout()
        model_row.addWidget(BodyLabel("模型:"))

        self.modelCombo = SearchableEditableComboBox()
        current_model = self.provider_info.get("模型名称", template.get("模型名称", ""))

        if self.is_new:
            if self.nameCombo.currentText() in PROVIDER_MODELS:
                self.modelCombo.addItems(PROVIDER_MODELS[self.nameCombo.currentText()])
            elif self.nameCombo.currentText() in FREE_PROVIDERS:
                default_model = FREE_PROVIDERS[self.nameCombo.currentText()].get("模型名称", "")
                if default_model:
                    self.modelCombo.addItem(default_model)
        elif self.provider_name in PROVIDER_MODELS:
            self.modelCombo.addItems(PROVIDER_MODELS[self.provider_name])
        elif self.provider_name in FREE_PROVIDERS:
            default_model = FREE_PROVIDERS[self.provider_name].get("模型名称", "")
            if default_model:
                self.modelCombo.addItem(default_model)

        if current_model:
            existing = [self.modelCombo.itemText(i) for i in range(self.modelCombo.count())]
            if current_model not in existing:
                self.modelCombo.addItem(current_model)
            idx = self.modelCombo.findText(current_model)
            if idx >= 0:
                self.modelCombo.setCurrentIndex(idx)
            else:
                self.modelCombo.setCurrentText(current_model)

        fetch_btn = PrimaryPushButton("获取模型列表")
        fetch_btn.setFixedSize(100, 28)
        fetch_btn.clicked.connect(self._fetch_models)
        model_row.addWidget(self.modelCombo, 1)
        model_row.addWidget(fetch_btn)
        model_layout.addLayout(model_row)

        self.fetchStatusLabel = BodyLabel("")
        self.fetchStatusLabel.setStyleSheet("color: #888888; font-size: 11px;")
        model_layout.addWidget(self.fetchStatusLabel)

        content_layout.addWidget(model_frame)

        # 参数配置区域
        param_frame = QFrame()
        param_frame.setStyleSheet("background-color: rgba(51, 51, 51, 180); border-radius: 8px;")
        param_layout = QVBoxLayout(param_frame)
        param_layout.setContentsMargins(16, 12, 16, 12)
        param_layout.setSpacing(12)

        param_title = BodyLabel("生成参数")
        param_title.setStyleSheet("color: #4fc3f7; font-size: 13px; font-weight: bold;")
        param_layout.addWidget(param_title)

        temp_row = QHBoxLayout()
        temp_row.addWidget(BodyLabel("温度:"))
        self.tempSpin = QDoubleSpinBox()
        self.tempSpin.setRange(0, 2)
        self.tempSpin.setSingleStep(0.1)
        self.tempSpin.setDecimals(2)
        self.tempSpin.setValue(self._original_info.get("温度", template.get("温度", 0.7)))
        temp_row.addWidget(self.tempSpin, 1)
        param_layout.addLayout(temp_row)

        context_row = QHBoxLayout()
        context_row.addWidget(BodyLabel("上下文长度:"))
        self.contextLengthSpin = QDoubleSpinBox()
        self.contextLengthSpin.setRange(1, 99999999)
        self.contextLengthSpin.setSingleStep(1000)
        self.contextLengthSpin.setDecimals(0)
        self.contextLengthSpin.setValue(
            self._original_info.get("最大Token", template.get("最大Token", 4096))
        )
        context_row.addWidget(self.contextLengthSpin, 1)
        param_layout.addLayout(context_row)

        content_layout.addWidget(param_frame)

        # 按钮区域
        btn_layout = QHBoxLayout()
        btn_layout.addStretch()

        cancel_btn = PushButton("取消")
        cancel_btn.setFixedSize(80, 32)
        cancel_btn.setStyleSheet("""
            QPushButton {
                background-color: #555555;
                color: white;
                border: none;
                border-radius: 4px;
                font-size: 12px;
            }
            QPushButton:hover {
                background-color: #666666;
            }
        """)
        cancel_btn.clicked.connect(self._on_cancel)
        btn_layout.addWidget(cancel_btn)

        save_btn = PrimaryPushButton("保存")
        save_btn.setFixedSize(80, 32)
        save_btn.clicked.connect(self._on_save)
        btn_layout.addWidget(save_btn)

        content_layout.addLayout(btn_layout)

        scroll.setWidget(content_widget)
        main_layout.addWidget(scroll, 1)

    def _load_preset_urls(self):
        """加载预设端点"""
        for name, info in FREE_PROVIDERS.items():
            url = info.get("API_URL", "")
            if url and self.apiUrlCombo.findText(url) < 0:
                self.apiUrlCombo.addItem(url)

    def _on_provider_changed(self, name: str):
        """服务商变化时更新预设值"""
        if name in FREE_PROVIDERS:
            info = FREE_PROVIDERS[name]
            if "API_URL" in info:
                self.apiUrlCombo.clear()
                self._load_preset_urls()

            if "模型名称" in info:
                self.modelCombo.clear()
                self.modelCombo.addItem(info["模型名称"])

    def _open_help_url(self, name: str):
        """打开帮助链接"""
        if name in FREE_PROVIDERS:
            import webbrowser
            url = FREE_PROVIDERS[name].get("获取地址", "")
            if url:
                webbrowser.open(url)

    def _fetch_models(self):
        """获取模型列表"""
        api_url = self.apiUrlCombo.currentText().strip()
        api_key = self.apiKeyEdit.text().strip()

        if not api_url or not api_key:
            self.fetchStatusLabel.setText("请先填写 API URL 和 Key")
            self.fetchStatusLabel.setStyleSheet("color: #e74c3c; font-size: 11px;")
            return

        provider_name = self.nameCombo.currentText() if self.is_new else self.provider_name

        # 显示加载状态
        self.fetchStatusLabel.setText("正在获取模型列表...")
        self.fetchStatusLabel.setStyleSheet("color: #888888; font-size: 11px;")

        def do_fetch():
            try:
                headers = {"Authorization": f"Bearer {api_key}"}
                urls_to_try = [
                    f"{api_url.rstrip('/')}/v1/models",
                    f"{api_url.rstrip('/')}/api/models",
                ]
                models = []
                for url in urls_to_try:
                    try:
                        resp = requests.get(url, headers=headers, timeout=10)
                        if resp.status_code == 200:
                            data = resp.json()
                            if "data" in data:
                                for item in data["data"]:
                                    model_id = item.get("id", "")
                                    if model_id and _is_text_chat_model(model_id):
                                        models.append(model_id)
                            elif "models" in data:
                                for item in data["models"]:
                                    model_id = item.get("id", "") or item.get("name", "")
                                    if model_id and _is_text_chat_model(model_id):
                                        models.append(model_id)
                            if models:
                                break
                    except Exception:
                        continue
                return models
            except Exception:
                return []

        import threading
        thread = threading.Thread(target=self._do_fetch_thread, args=(do_fetch,))
        thread.daemon = True
        thread.start()

    def _do_fetch_thread(self, fetch_func):
        """在后台线程中获取模型"""
        import time
        time.sleep(0.1)  # 等待 UI 更新
        models = fetch_func()
        from loguru import logger
        logger.info(f"[ProviderEditCard] Fetched {len(models)} models")
        # 使用信号更新 UI
        if models:
            self._fetched_models = models
            self.fetchStatusLabel.setText(f"成功获取 {len(models)} 个模型")
            self.fetchStatusLabel.setStyleSheet("color: #2ecc71; font-size: 11px;")
            self.modelCombo.clear()
            self.modelCombo.addItems(models)
            idx = self.modelCombo.findText(self._original_info.get("模型名称", ""))
            if idx >= 0:
                self.modelCombo.setCurrentIndex(idx)
        else:
            self.fetchStatusLabel.setText("获取模型列表失败，请检查 API 配置")
            self.fetchStatusLabel.setStyleSheet("color: #e74c3c; font-size: 11px;")

    def _on_save(self):
        """保存"""
        provider_name = self.nameCombo.currentText() if self.is_new else self.provider_name
        self.provider_info = {
            "API_URL": self.apiUrlCombo.currentText().strip(),
            "API_KEY": self.apiKeyEdit.text().strip(),
            "模型名称": self.modelCombo.currentText().strip(),
            "温度": self.tempSpin.value(),
            "最大Token": int(self.contextLengthSpin.value()),
            "认证方式": "bearer",
        }
        if self._fetched_models:
            self.provider_info["模型列表"] = self._fetched_models
        self.saved.emit(provider_name, self.provider_info)

    def _on_cancel(self):
        """取消"""
        self.closed.emit()

    def get_result(self):
        """获取结果"""
        if self.is_new:
            return self.nameCombo.currentText(), self.provider_info
        return self.provider_name, self.provider_info


def _is_text_chat_model(model_id: str) -> bool:
    """判断模型是否为文本聊天模型"""
    if not model_id:
        return False
    model_lower = model_id.lower()
    non_text_keywords = [
        'dall-e', 'dalle', 'stable-diffusion', 'sd-', 'imagen', 'flux',
        'image', 'diffusion', 'kandinsky', 'midjourney', "wan",
        'whisper', 'tts', 'speech', 'audio', 'piper', "voice",
        'embedding', 'embed', 'text-embedding', 'bge',
        'moderation', 'rerank', 'search', 'retrieval',
    ]
    for keyword in non_text_keywords:
        if keyword in model_lower:
            return False
    return True
