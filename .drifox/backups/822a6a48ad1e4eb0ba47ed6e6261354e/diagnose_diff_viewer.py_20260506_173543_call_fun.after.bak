# -*- coding: utf-8 -*-
"""
诊断脚本：检测 diff_viewer.py 的性能和内存问题
"""

import sys
import os
import time
import tracemalloc
import gc
from io import StringIO
from contextlib import contextmanager

# 设置路径
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

@contextmanager
def memory_profile(name=""):
    """内存使用上下文管理器"""
    gc.collect()
    tracemalloc.start()
    snapshot_before = tracemalloc.take_snapshot()
    
    start_time = time.perf_counter()
    start_mem = tracemalloc.get_traced_memory()[0]
    
    yield
    
    end_time = time.perf_counter()
    end_mem = tracemalloc.get_traced_memory()[0]
    snapshot_after = tracemalloc.take_snapshot()
    
    tracemalloc.stop()
    
    print(f"\n{'='*60}")
    print(f"【{name}】")
    print(f"{'='*60}")
    print(f"  执行时间: {(end_time - start_time)*1000:.2f} ms")
    print(f"  内存增量: {(end_mem - start_mem)/1024:.2f} KB")
    
    # 显示 Top 10 内存分配
    top_stats = snapshot_after.compare_to(snapshot_before, 'lineno')
    print(f"\n  内存分配 TOP 10:")
    for i, stat in enumerate(top_stats[:10], 1):
        print(f"    {i}. {stat}")


def generate_large_diff(num_files=50, lines_per_file=500):
    """生成大量 diff 测试数据"""
    diff_parts = []
    
    for i in range(num_files):
        old_lines = [f"// Old line {j} in file {i}\n" for j in range(lines_per_file)]
        new_lines = [f"// New line {j} in file {i}\n" for j in range(lines_per_file)]
        
        # 添加一些修改
        for j in range(0, lines_per_file, 10):
            if j + 5 < lines_per_file:
                new_lines[j] = f"// Modified line {j} in file {i}\n"
        
        import difflib
        diff = difflib.unified_diff(
            old_lines, new_lines,
            fromfile=f"old/file_{i}.txt",
            tofile=f"new/file_{i}.txt",
            lineterm='\n'
        )
        diff_parts.append(''.join(diff))
    
    return ''.join(diff_parts)


def test_css_memory():
    """测试 CSS 字符串的内存占用"""
    from app.utils.diff_viewer import DiffHtmlGenerator
    
    print("\n" + "="*60)
    print("【CSS 内存占用测试】")
    print("="*60)
    
    css_size = sys.getsizeof(DiffHtmlGenerator.GITHUB_DARK_CSS)
    css_len = len(DiffHtmlGenerator.GITHUB_DARK_CSS)
    
    print(f"  CSS 字符串长度: {css_len:,} 字符")
    print(f"  CSS 内存占用: {css_size:,} bytes ({css_size/1024:.2f} KB)")
    
    # 测试 CSS 是否被正确复用
    print(f"\n  CSS 对象 ID: {id(DiffHtmlGenerator.GITHUB_DARK_CSS)}")
    return css_size


def test_parse_diff_performance(diff_output):
    """测试 _parse_diff 方法的性能"""
    from app.utils.diff_viewer import DiffHtmlGenerator
    
    gc.collect()
    tracemalloc.start()
    
    start = time.perf_counter()
    files = DiffHtmlGenerator._parse_diff(diff_output)
    end = time.perf_counter()
    
    current, peak = tracemalloc.get_traced_memory()
    tracemalloc.stop()
    
    print(f"\n  解析 {len(files)} 个文件的 diff:")
    print(f"    执行时间: {(end - start)*1000:.2f} ms")
    print(f"    当前内存: {current/1024:.2f} KB")
    print(f"    峰值内存: {peak/1024:.2f} KB")


def test_html_generation_performance(diff_output):
    """测试 HTML 生成的性能"""
    from app.utils.diff_viewer import DiffHtmlGenerator
    
    gc.collect()
    tracemalloc.start()
    
    start = time.perf_counter()
    html = DiffHtmlGenerator.generate_html_report(diff_output, "test_session", lazy_load=True)
    end = time.perf_counter()
    
    current, peak = tracemalloc.get_traced_memory()
    tracemalloc.stop()
    
    print(f"\n  HTML 生成:")
    print(f"    执行时间: {(end - start)*1000:.2f} ms")
    print(f"    当前内存: {current/1024:.2f} KB")
    print(f"    峰值内存: {peak/1024:.2f} KB")
    print(f"    HTML 大小: {len(html)/1024:.2f} KB")
    
    return html


def test_string_concat_efficiency():
    """测试字符串拼接效率问题"""
    print("\n" + "="*60)
    print("【字符串拼接效率测试】")
    print("="*60)
    
    iterations = 10000
    small_string = "x" * 100
    
    # 方法1: += 拼接
    gc.collect()
    start = time.perf_counter()
    result = ""
    for _ in range(iterations):
        result += small_string
    end = time.perf_counter()
    time1 = (end - start) * 1000
    
    # 方法2: list + join
    gc.collect()
    start = time.perf_counter()
    parts = []
    for _ in range(iterations):
        parts.append(small_string)
    result = "".join(parts)
    end = time.perf_counter()
    time2 = (end - start) * 1000
    
    print(f"  {iterations} 次 100 字符字符串拼接:")
    print(f"    += 拼接: {time1:.2f} ms")
    print(f"    list+join: {time2:.2f} ms")
    print(f"    效率比: {time1/time2:.2f}x (list+join 更快)")


def analyze_code_patterns():
    """分析代码中的低效模式"""
    print("\n" + "="*60)
    print("【代码模式分析】")
    print("="*60)
    
    from app.utils.diff_viewer import DiffHtmlGenerator
    import inspect
    
    source = inspect.getsource(DiffHtmlGenerator.generate_html_report)
    
    # 检测 += 字符串拼接
    concat_count = source.count("+=")
    plus_eq_in_html = source.count(" += ")
    
    # 检测 list + join 模式
    has_list_pattern = "list()" in source or ".append(" in source
    has_join = ".join(" in source
    
    # 检测是否存在多次循环
    lines = source.split('\n')
    for_count = sum(1 for line in lines if ' for ' in line and ' in ' in line)
    
    print(f"  generate_html_report 方法分析:")
    print(f"    += 字符串拼接: {plus_eq_in_html} 处")
    print(f"    for 循环: {for_count} 个")
    print(f"    使用 list 模式: {has_list_pattern}")
    print(f"    使用 join: {has_join}")


def test_lazy_load_effectiveness(html):
    """测试懒加载机制的有效性"""
    print("\n" + "="*60)
    print("【懒加载机制测试】")
    print("="*60)
    
    import re
    
    # 检查是否包含懒加载数据
    has_diff_files = 'window._diffFiles' in html
    has_preload = 'window._preloadCount' in html
    
    # 计算预渲染 vs 懒加载的数据量
    preload_match = re.search(r'window\._preloadCount\s*=\s*(\d+)', html)
    preload_count = int(preload_match.group(1)) if preload_match else 0
    
    # 计算实际预渲染的文件数量
    file_block_count = html.count('class="file-block"')
    
    # 估算完整数据大小
    json_match = re.search(r'window\._diffFiles\s*=\s*(\[.*?\]);', html, re.DOTALL)
    if json_match:
        json_data_size = len(json_match.group(1))
        print(f"  JSON 数据大小: {json_data_size/1024:.2f} KB")
    
    print(f"  懒加载机制:")
    print(f"    _diffFiles 存在: {has_diff_files}")
    print(f"    _preloadCount: {preload_count}")
    print(f"    预渲染文件数: {file_block_count}")
    
    if file_block_count > preload_count:
        print(f"  ⚠️  警告: 预渲染文件数 ({file_block_count}) > preload_count ({preload_count})")
        print(f"     可能导致懒加载失效")


def test_window_cleanup():
    """测试窗口关闭后的资源清理"""
    print("\n" + "="*60)
    print("【窗口资源清理测试】")
    print("="*60)
    
    from app.utils.diff_viewer import DiffViewerWindow
    
    initial_count = len(DiffViewerWindow._instances)
    print(f"  初始实例数量: {initial_count}")
    
    # 检查 close_all 方法
    print(f"  close_all 方法存在: {hasattr(DiffViewerWindow, 'close_all')}")
    print(f"  _on_closed 方法存在: {hasattr(DiffViewerWindow, '_on_closed')}")


def run_diagnose():
    """运行完整诊断"""
    print("="*60)
    print("  DIFF VIEWER 性能与内存诊断")
    print("="*60)
    
    # 1. CSS 内存占用
    css_size = test_css_memory()
    
    # 2. 字符串拼接效率测试
    test_string_concat_efficiency()
    
    # 3. 代码模式分析
    analyze_code_patterns()
    
    # 4. 小规模 diff 测试
    print("\n" + "="*60)
    print("【小规模测试 (5 文件, 100 行/文件)】")
    print("="*60)
    small_diff = generate_large_diff(num_files=5, lines_per_file=100)
    print(f"  Diff 大小: {len(small_diff)/1024:.2f} KB")
    test_parse_diff_performance(small_diff)
    html_small = test_html_generation_performance(small_diff)
    
    # 5. 中规模 diff 测试
    print("\n" + "="*60)
    print("【中规模测试 (20 文件, 200 行/文件)】")
    print("="*60)
    medium_diff = generate_large_diff(num_files=20, lines_per_file=200)
    print(f"  Diff 大小: {len(medium_diff)/1024:.2f} KB")
    test_parse_diff_performance(medium_diff)
    html_medium = test_html_generation_performance(medium_diff)
    
    # 6. 懒加载有效性测试
    test_lazy_load_effectiveness(html_medium)
    
    # 7. 大规模 diff 测试（可能较慢）
    print("\n" + "="*60)
    print("【大规模测试 (50 文件, 500 行/文件)】")
    print("="*60)
    large_diff = generate_large_diff(num_files=50, lines_per_file=500)
    print(f"  Diff 大小: {len(large_diff)/1024:.2f} KB")
    test_parse_diff_performance(large_diff)
    html_large = test_html_generation_performance(large_diff)
    test_lazy_load_effectiveness(html_large)
    
    # 8. 窗口资源清理
    test_window_cleanup()
    
    # 总结
    print("\n" + "="*60)
    print("  诊断总结")
    print("="*60)
    
    issues = []
    
    if css_size > 100000:  # > 100KB
        issues.append("⚠️  CSS 字符串过大 ({:.2f} KB)，每次类加载都占用内存".format(css_size/1024))
    
    issues.append("⚠️  generate_html_report 使用 += 字符串拼接，效率较低")
    issues.append("⚠️  所有文件数据都存储在 window._diffFiles JSON 中，懒加载不彻底")
    issues.append("⚠️  预渲染文件数量与 preload_count 可能不一致")
    
    if issues:
        print("\n发现的问题:")
        for issue in issues:
            print(f"  {issue}")
    else:
        print("  未发现明显问题")
    
    return issues


if __name__ == "__main__":
    try:
        issues = run_diagnose()
    except Exception as e:
        print(f"\n诊断过程出错: {e}")
        import traceback
        traceback.print_exc()
