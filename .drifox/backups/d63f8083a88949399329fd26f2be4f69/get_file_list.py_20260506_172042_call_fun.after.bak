"""
获取文件列表
"""
import argparse  # noqa: F401
import json
import datetime
import requests
from loguru import logger


def get_file_list(start_date: str, end_date: str) -> dict:
    """
    获取指定时间段内的文件列表
    
    Args:
        start_date: 开始时间，格式如 "2023-12-01 00:00:00"
        end_date: 结束时间，格式如 "2023-12-31 23:59:59"
    
    Returns:
        文件名字典，格式: {文件名: {"name": "完整文件名", "uuid": "文件uuid"}}
    """
    url = f"http://10.246.11.125:8080/open/SNPDP/DCTMexchange/syncTechDoc?startDate={start_date}&endDate={end_date}"
    results = {}
    
    try:
        response = requests.get(url)
        response.encoding = "utf-8"
        json_dict = response.json()
        data_list = json_dict["msg"]
        
        # 支持的文件类型
        valid_extensions = ["pdf", "doc", "docx", "txt", "py", "csv", "ppt", "pptx"]
        
        for item in data_list:
            # 处理主文件
            if item['cm:name'] not in results and item.get("extension") in valid_extensions:
                results[item['cm:name']] = {
                    "name": f"{item['cm:name']}.{item['extension']}",
                    "uuid": item["sys:node-uuid"]
                }
            
            # 处理关联文件
            for related_item in item.get("relation", []):
                if related_item['cm:name'] not in results and related_item.get("extension") in valid_extensions:
                    results[related_item['cm:name']] = {
                        "name": f"{related_item['cm:name']}.{related_item['extension']}",
                        "uuid": related_item["sys:node-uuid"]
                    }
                    
    except Exception as e:
        logger.error(f"获取文件列表错误，错误信息: {e}")
        
    logger.info(f"已获取 {start_date} ~ {end_date} 时间段文件，文件总数：{len(results)}")
    return results


def main(start_date: str, end_date: str, output: str = "file_list.json"):
    """
    获取文件列表
    
    Args:
        start_date: 开始时间，格式 "YYYY-MM-DD HH:MM:SS"
        end_date: 结束时间，格式 "YYYY-MM-DD HH:MM:SS"
        output: 输出文件路径
    """
    results = get_file_list(start_date, end_date)
    
    with open(output, "w", encoding="utf-8") as f:
        json.dump(results, f, ensure_ascii=False, indent=2)
    
    logger.info(f"文件列表已保存到: {output}")


if __name__ == "__main__":
    main()