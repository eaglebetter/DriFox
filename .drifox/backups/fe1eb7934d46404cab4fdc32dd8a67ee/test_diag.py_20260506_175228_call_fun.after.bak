#!/usr/bin/env python
"""测试 DiagnosticsTools 功能"""
import sys
from pathlib import Path

# 添加项目根目录到 path
sys.path.insert(0, str(Path(__file__).parent))

from app.tools.diagnostics_tools import DiagnosticsTools

tools = DiagnosticsTools(Path('app/tools'))
result = tools.get_diagnostics('app/tools/diagnostics_tools.py')

print(f"Success: {result.success}", flush=True)
if result.content:
    print(f"Content:\n{result.content}", flush=True)
else:
    print("Content: None", flush=True)
if result.error:
    print(f"Error: {result.error}", flush=True)
