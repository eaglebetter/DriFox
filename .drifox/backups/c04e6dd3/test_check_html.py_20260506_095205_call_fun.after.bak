"""检查 HTML 中 args-value 的具体内容"""
import sys
sys.path.insert(0, 'app')

from utils.message_content import content_to_markdown, make_tool_result_block
from widgets.message_card import _render_tool_block_content, _inject_tool_blocks
import re

content_code = '''# -*- coding: utf-8 -*-
\"\"\"
模型选择弹窗
\"\"\"
class Widget:
    def method(self, event):
        if event.type() == event.MouseButtonPress:
            if obj.rect().contains(event.pos()):
                self.update()
'''

test_args = {
    "content": content_code,
    "path": "app\\widgets\\model_selector_popup.py"
}

block = make_tool_result_block(
    tool_name="write",
    arguments=test_args,
    result="Successfully written",
    success=True,
    tool_call_id="call_func_123"
)

markdown = content_to_markdown([block])
full_md = f'<tool>\n{markdown.replace("<tool>\n", "").replace("</tool>", "")}\n</tool>'

# 处理工具块
processed = _inject_tool_blocks(full_md, completed=True)

print("=" * 60)
print("检查 HTML 中的 args-value 元素:")
print("=" * 60)

# 提取所有 args-value 元素
value_pattern = re.compile(r'<span class="args-key"[^>]*>([^<]+)</span>\s*<span class="args-value"[^>]*>([^<]*)</span>', re.DOTALL)
for match in value_pattern.finditer(processed):
    key = match.group(1)
    value = match.group(2)
    print(f"\nKey: {key}")
    print(f"Value 前 100 字符: {value[:100]}...")
    print(f"Value 长度: {len(value)}")

print("\n" + "=" * 60)
print("完整的 args-row HTML:")
print("=" * 60)

row_pattern = re.compile(r'<div class="args-row"[^>]*>(.*?)</div>', re.DOTALL)
for match in row_pattern.finditer(processed):
    row_html = match.group(1)
    key_match = re.search(r'class="args-key"[^>]*>([^<]+)</span>', row_html)
    if key_match:
        print(f"\n参数行: {key_match.group(1)}")
        print(f"HTML: {row_html[:200]}...")
