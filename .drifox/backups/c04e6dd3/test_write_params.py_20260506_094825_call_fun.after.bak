"""测试 write 工具参数的完整解析流程"""
import sys
sys.path.insert(0, 'app')

from utils.message_content import content_to_markdown, make_tool_result_block

# 模拟 write 工具的真实参数（包含大量代码）
content_code = '''# -*- coding: utf-8 -*-
\"\"\"
扁平式模型选择上拉框
\"\"\"
class Test:
    def __init__(self):
        self.setStyleSheet(\"\"\"
            QWidget {
                background-color: #2b2b2b;
            }
        \"\"\")

    def method(self, event):
        if event.type() == event.MouseButtonPress:
            if obj.rect().contains(event.pos()):
                self.update()
'''

test_args = {
    "content": content_code,
    "path": "app\\widgets\\model_selector_popup.py"
}

print("=" * 60)
print("原始参数:")
print(f"  content 长度: {len(test_args['content'])}")
print(f"  path: {test_args['path']}")
print("=" * 60)

# 1. 创建 block
block = make_tool_result_block(
    tool_name="write",
    arguments=test_args,
    result="Successfully written",
    success=True,
    tool_call_id="test_id"
)

print(f"\nBlock arguments 类型: {type(block['arguments'])}")
print(f"Block arguments 内容: {block['arguments']}")

# 2. 转换为 markdown
markdown = content_to_markdown([block])

print("\n" + "=" * 60)
print("生成的 Markdown:")
print("=" * 60)
print(markdown[:1000] + "..." if len(markdown) > 1000 else markdown)

# 3. 模拟 _render_tool_block_content 的解析过程
import re
import json

print("\n" + "=" * 60)
print("测试解析流程:")
print("=" * 60)

# 提取 args 部分
args_match = re.search(r'args: ({.*?})\s*\nresult:', markdown, re.DOTALL)
if args_match:
    args_json = args_match.group(1)
    print(f"\n提取的 JSON 字符串长度: {len(args_json)}")
    print(f"提取的 JSON 字符串前 200 字符: {args_json[:200]}...")
    
    # 尝试解析
    try:
        parsed = json.loads(args_json)
        print(f"\n✅ JSON 解析成功!")
        print(f"  解析出的参数: {list(parsed.keys())}")
        print(f"  content 长度: {len(parsed.get('content', ''))}")
        print(f"  path: {parsed.get('path')}")
    except json.JSONDecodeError as e:
        print(f"\n❌ JSON 解析失败: {e}")
        print(f"错误位置: {e.pos}")
        print(f"错误上下文: ...{args_json[max(0,e.pos-30):e.pos+30]}...")
else:
    print("❌ 无法提取 args JSON")
