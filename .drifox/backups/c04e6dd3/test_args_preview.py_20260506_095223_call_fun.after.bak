"""检查参数预览"""
import sys
sys.path.insert(0, 'app')

from utils.message_content import content_to_markdown, make_tool_result_block
from widgets.render_helpers import _format_args_preview

content_code = '''# -*- coding: utf-8 -*-
\"\"\"
模型选择弹窗
\"\"\"
class Widget:
    def method(self, event):
        if event.type() == event.MouseButtonPress:
            if obj.rect().contains(event.pos()):
                self.update()
'''

test_args = {
    "content": content_code,
    "path": "app\\widgets\\model_selector_popup.py"
}

print("参数:", test_args)
print()

# 测试 _format_args_preview
preview = _format_args_preview(test_args)
print(f"参数预览结果: {preview}")
print(f"预览长度: {len(preview)}")

print("\n" + "=" * 60)
print("问题分析:")
print("=" * 60)
print("""
当 content 参数很长时：
1. content 的值（前 80 字符）就已经占据了大部分预览空间
2. path 参数可能被挤出预览区域

这解释了为什么用户说 "参数不显示"：
- 折叠状态下，预览区域只显示 content 的截断内容
- path 被 content 的长内容"挤掉"了

但是：
- 展开后的表格是正确显示所有参数的
- 问题是预览区域不够友好
""")
